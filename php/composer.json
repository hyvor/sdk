{
    "name": "hyvor/sdk-php",
    "description": "Official PHP SDK for Hyvor products (Talk, Post)",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "ext-curl": "*",
        "ext-json": "*",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Hyvor\\Sdk\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Hyvor\\Sdk\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "test": "phpunit"
    }
}
