{
    "name": "hyvor/sdk",
    "description": "Official PHP SDK for HYVOR products",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.4",
        "ext-json": "*",
        "psr/log": "^3.0",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.1",
        "psr/http-message": "^1.1 || ^2.0",
        "php-http/discovery": "^1.20",
        "symfony/serializer": "^8.1",
        "symfony/property-info": "^8.1",
        "symfony/property-access": "^8.1",
        "phpdocumentor/reflection-docblock": "^6.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "nyholm/psr7": "^1.8",
        "guzzlehttp/guzzle": "^7.15",
        "phpstan/phpstan": "^2.2",
        "friendsofphp/php-cs-fixer": "^3.95"
    },
    "autoload": {
        "psr-4": {
            "Hyvor\\Sdk\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Hyvor\\Sdk\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
